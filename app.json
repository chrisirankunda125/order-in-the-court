{
  "expo": {
    "name": "Order in the Court",
    "slug": "order-in-the-court",
    "scheme": "orderinthecourt",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C1C1C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.orderinthecourt.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow Order in the Court to attach photos to your training sessions.",
        "NSCameraUsageDescription": "Allow Order in the Court to take photos for training sessions."
      }
    },
    "android": {
      "package": "com.orderinthecourt.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1C1C1C"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Order in the Court to attach photos to your training sessions."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "order-in-the-court"
      }
    }
  }
}
